name: "天气流量日历"
description: "天气流量日历小组件"
env_schema:
  QW_HOST:
    name: 项目地址
    description: 创建的项目地址
  QW_KEY:
    name: 令牌
    description: 和风天气申请API令牌
icon: "https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/apps/Apple_Weather.png"
scriptings:
- http_request:
    name: 和风
    match: weatherkit\.apple\.com\/api\/v\d+\/weather\/[^/]+\/(-?\d+\.?\d*)\/(-?\d+\.?\d*)
    script_url: https://raw.githubusercontent.com/changzhongxinxin/ModuRule/main/js/小组件/更新经纬度
    body_required: false
    binary_body: false
- generic:
    name: 天气流量日历
    script_url: https://raw.githubusercontent.com/changzhongxinxin/ModuRule/main/js/小组件/天气流量日历
- generic:
    name: 黄历
    script_url: https://raw.githubusercontent.com/xcgtb/Egern-Widgets/main/HL.js
- generic:
    name: 网络雷达
    script_url: https://raw.githubusercontent.com/xcgtb/Egern-Widgets/main/Network-Pro.js
widgets:
- name: 天气流量日历
  script_name: 天气流量日历
- name: 网络雷达
  script_name: 网络雷达
- name: 黄历
  script_name: 黄历
mitm:
  hostnames:
    includes:
    - weatherkit.apple.com
