name: "SNI 域名替换(Egern版)"
description: "将域名重写到指定目标域名，绕过 SNI 阻断"
compat_arguments:
  RuleBlock: true
  domain: "789828.xyz"
compat_arguments_schema:
  RuleBlock:
    name: "允许播放进度上报"
    description: "允许播放进度规则"
    default_value: true
    options:
    - true
    - false
  domain:
    name: "域名"
    description: "要替换的域名"
    default_value: "789828.xyz"
icon: "https://raw.githubusercontent.com/xushier/HD-Icons/main/circle/ddns-1.png"
rules:
- url_regex:
    name: "拦截数据上报"
    match: "/Sessions/Playing(/Progress|/Stopped)?"
    policy: "REJECT-DROP"
    disabled: {{{RuleBlock}}}
url_rewrites:
- match: "^https?://(emby|proxy)\\.com"
  location: "https://$1.{{{domain}}}"
mitm:
  hostnames:
    includes:
    - "emby.com"
    - "proxy.com"
