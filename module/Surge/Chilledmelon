#!name=Chilledmelon 保号提醒
#!desc=自动检测登录状态，过期自动重新登录并通知。支持通过参数或 BoxJS 配置。
#!category=工具
#!icon=https://raw.githubusercontent.com/ginibond/ginibond/main/Icons/Forward/Bingzhenxigua.png
#!arguments=用户名:请填写账号, 密码:请填写密码,到期前多少天提醒:3,提醒时间:"0 6,12,18,0 * * *"


[Rule]
#DOMAIN,www.chilledmelon.com,proxy

[Script]
西瓜保号通知 = type=cron,cronexp="{{{提醒时间}}}",wake-system=1,script-path=https://raw.githubusercontent.com/changzhongxinxin/ModuRule/main/js/Chilledmelon.js,script-update-interval=0,timeout=60,argument=username={{{用户名}}}&password={{{密码}}}&day={{{到期前多少天提醒}}}
