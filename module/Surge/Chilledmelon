#!name=Chilledmelon 保号提醒
#!desc=自动检测登录状态，过期自动重新登录并通知。支持通过参数或 BoxJS 配置。
#!category=工具
#!icon=https://raw.githubusercontent.com/ginibond/ginibond/main/Icons/Forward/Bingzhenxigua.png
#!arguments=username:请填写账号, password:请填写密码,day:3,cron:"0 6,12,18,0 * * *"
#!arguments-desc=[参数设置]\n\n⓵ username: 填写账号。\n\n⓶ password: 填写密码。\n\n⓷ day: 剩余天数低于此数值时通知。\n\n⓸ cron: 自定义执行时间 (Cron 表达式)，默认每 6 小时执行一次。

[Rule]
#DOMAIN,www.chilledmelon.com,proxy

[Script]
西瓜保号通知 = type=cron,cronexp="{{{cron}}}",wake-system=1,script-path=https://raw.githubusercontent.com/changzhongxinxin/ModuRule/main/js/Chilledmelon.js,script-update-interval=0,timeout=60,argument=username={{{username}}}&password={{{password}}}&day={{{day}}}
