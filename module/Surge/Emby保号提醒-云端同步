#!name=Emby保号提醒通知-云端同步
#!desc=存储播放停止时间到EdgeGist云端，定时巡检比较并通知保号
#!category=工具
#!icon=https://raw.githubusercontent.com/nori5555/nori-emby/main/icons/emby.png
#!arguments=gistUrl:请填写Gist地址,Token:请填写Token,gistDescription:"",gistFilename:""
#!arguments-desc=[参数设置]\n\n⓵ gistUrl: Gist部署地址，如 https://xxx.workers.dev\n\n⓶ Token: TOKEN值\n\n⓷ gistDescription: Gist描述（留空默认：Emby Keepalive Data）\n\n⓸ gistFilename: Gist文件名（留空默认：emby_keepalive_data.json）


[Script]
巡检通知 = type=cron,cronexp="0 6,12,18,0 * * *",wake-system=1,script-path=https://raw.githubusercontent.com/changzhongxinxin/ModuRule/main/js/保号/巡检-云端同步.js,script-update-interval=0,timeout=30,argument=gistUrl={{{gistUrl}}}&Token={{{Token}}}&gistDescriptionription={{{gistDescription}}}&gistFilenamename={{{gistFilename}}}

播放停止触发 = type=http-response,pattern=^https?:\/\/[^\/]+\/.*(Stopped|Playing\/Stop|ReportPlaybackStopped|Playback\/Stop),requires-body=0,timeout=30,script-path=https://raw.githubusercontent.com/changzhongxinxin/ModuRule/main/js/保号/触发-云端同步.js,script-update-interval=0,argument=gistUrl={{{gistUrl}}}&Token={{{Token}}}&gistDescriptionription={{{gistDescription}}}&gistFilenamename={{{gistFilename}}}

[MITM]
hostname = %INSERT% *.feiyue.lol,*.miraiemby.com,embymv.link,*lunarisvault.com,lite.cn2gias.uk