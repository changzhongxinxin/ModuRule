#!name=Emby保号提醒通知-云端同步
#!desc=存储播放停止时间到EdgeGist云端，定时巡检比较并通知保号
#!category=工具
#!icon=https://raw.githubusercontent.com/nori5555/nori-emby/main/icons/emby.png
#!arguments=Gist地址:请填写Gist地址,Gist密码:请填写密码,Gist描述:"",文件名:""
#!arguments-desc=[参数设置]\n\n Gist描述（留空默认：Emby Keepalive Data）\n\n 文件名（留空默认：emby_keepalive_data.json）


[Script]
巡检通知 = type=cron,cronexp="0 6,12,18,0 * * *",wake-system=1,script-path=https://raw.githubusercontent.com/changzhongxinxin/ModuRule/main/js/保号/巡检-云端同步.js,script-update-interval=0,timeout=30,argument=gistUrl={{{Gist地址}}}&Token={{{Gist密码}}}&gistDescriptionription={{{Gist描述}}}&gistFilenamename={{{文件名}}}

播放停止触发 = type=http-response,pattern=^https?:\/\/[^\/]+\/.*(Stopped|Playing\/Stop|ReportPlaybackStopped|Playback\/Stop),requires-body=0,timeout=30,script-path=https://raw.githubusercontent.com/changzhongxinxin/ModuRule/main/js/保号/触发-云端同步.js,script-update-interval=0,argument=gistUrl={{{Gist地址}}}&Token={{{Gist密码}}}&gistDescriptionription={{{Gist描述}}}&gistFilenamename={{{文件名}}}

[MITM]
hostname = %INSERT% *.feiyue.lol,*.miraiemby.com,embymv.link,*lunarisvault.com,lite.cn2gias.uk