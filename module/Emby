#!name=Emby上报拦截
#!desc=拦截部分Emby进度上报
#!tag = 工具
#!icon=https://raw.githubusercontent.com/ginibond/ginibond/main/Icons/Forward/Nsfw_emby_qiumingshanjuezhan1.png

[Rule]
# URL-REGEX,"^(?=.*(?:uhd|entertang)).*\/Sessions\/Playing(?:\/Progress|\/Stopped)?",REJECT-DROP

AND,((OR,((URL-REGEX,/Sessions/Playing$), (URL-REGEX,/Sessions/Playing/Progress), (URL-REGEX,/Sessions/Playing/Stopped))), (OR,((DOMAIN-KEYWORD,uhd), (DOMAIN-KEYWORD,entertang)))),REJECT-DROP


[MITM]
hostname = *.entertang.work, *.uhdnow.com
